build /data/1c7611/LQVG_3D/models/ops/build/temp.linux-x86_64-cpython-310/data/1c7611/LQVG_3D/models/ops/src/cuda/ms_deform_attn_cuda.o: cuda_compile /data/1c7611/LQVG_3D/models/ops/src/cuda/ms_deform_attn_cuda.cu
build /data/1c7611/LQVG_3D/models/ops/build/temp.linux-x86_64-cpython-310/data/1c7611/LQVG_3D/models/ops/src/vision.o: compile /data/1c7611/LQVG_3D/models/ops/src/vision.cpp








